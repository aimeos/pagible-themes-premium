{
    "label": "Premium",
    "description": "Modern, product-focused design with blue brand accents, large rounded cards, alternating sections, and bold typography",
    "maintainer": "Aimeos",
    "email": "info@aimeos.org",
    "website": "https://pagible.com",
    "types": {
        "page": {
            "sections": [
                "main",
                "footer"
            ]
        },
        "docs": {
            "sections": [
                "main",
                "footer"
            ]
        },
        "blog": {
            "sections": [
                "main",
                "footer"
            ]
        }
    },
    "config": {
        "theme": {
            "group": "basic",
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\"><path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>",
            "fields": {
                "--pico-font-family-sans-serif": {
                    "type": "string",
                    "default": "ui-sans-serif, sans-serif"
                },
                "--pico-color": {
                    "type": "color",
                    "default": "#0F172A"
                },
                "--pico-background-color": {
                    "type": "color",
                    "default": "#F8F9FA"
                },
                "--pico-text-selection-color": {
                    "type": "color",
                    "default": "#DBEAFE"
                },
                "--pico-contrast": {
                    "type": "color",
                    "default": "#0F172A"
                },
                "--pico-contrast-hover": {
                    "type": "color",
                    "default": "#020617"
                },
                "--pico-contrast-inverse": {
                    "type": "color",
                    "default": "#FDFEFF"
                },
                "--pico-primary": {
                    "type": "color",
                    "default": "#991B1B"
                },
                "--pico-primary-background": {
                    "type": "color",
                    "default": "#991B1B10"
                },
                "--pico-primary-hover": {
                    "type": "color",
                    "default": "#7F1D1D"
                },
                "--pico-primary-hover-background": {
                    "type": "color",
                    "default": "#7F1D1D10"
                },
                "--pico-secondary": {
                    "type": "color",
                    "default": "#4338CA"
                },
                "--pico-secondary-background": {
                    "type": "color",
                    "default": "#4338CA10"
                },
                "--pico-secondary-hover": {
                    "type": "color",
                    "default": "#3730A3"
                },
                "--pico-secondary-hover-background": {
                    "type": "color",
                    "default": "#3730A310"
                },
                "--pico-border-radius": {
                    "type": "string",
                    "default": "0.5rem"
                },
                "--pico-nav-breadcrumb-divider": {
                    "type": "string",
                    "default": "/"
                }
            }
        }
    }
}
